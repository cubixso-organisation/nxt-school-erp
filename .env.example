# Copy this file to .env and fill in real values.
# .env is gitignored. NEVER commit real secrets.

# ---- Database ----
DB_DSN="mysql:host=localhost;dbname=nxt_backend"
DB_USERNAME=root
DB_PASSWORD=

# ---- Yii cookie validation ----
# Generate a random 32+ char string. Required for cookie/session security.
COOKIE_VALIDATION_KEY=

# ---- SendGrid SMTP (mailer) ----
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# ---- Google Maps ----
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ---- Firebase service-account JSONs ----
# Store outside the repo (e.g. ~/.config/nxtschools/) and set absolute paths.
FIREBASE_NXTSCHOOL_KEY_PATH=
FIREBASE_ESTUDENT_KEY_PATH=

# ---- Anthropic API (RAG / AI tools) ----
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
